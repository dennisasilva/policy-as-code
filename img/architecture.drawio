        <mxCell id="e6" value="regras (checkout)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#3F8DDA;dashed=1;" edge="1" parent="1" source="checkov" target="gate"><mxGeometry relative="1" as="geometry" /></mxCell>
