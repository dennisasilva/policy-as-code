        <!-- ================= EDGES ================= -->
        <mxCell id="e1" value="abre PR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#5B6770;" edge="1" parent="1" source="devs" target="repoA"><mxGeometry relative="1" as="geometry" /></mxCell>
