        <!-- ================= BLOCKED (terminal) ================= -->
        <mxCell id="blocked" value="Merge bloqueado" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#F8D7DA;strokeColor=#D13212;fontColor=#842029;fontStyle=1;" vertex="1" parent="1">
