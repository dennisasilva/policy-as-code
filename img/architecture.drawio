<mxfile host="app.diagrams.net" type="device">
  <diagram id="policy-as-code" name="Policy-as-Code">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ================= LEFT COLUMN (stacked) ================= -->
        <mxCell id="cc" value="Repositórios consumidores (IaC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#3F8DDA;verticalAlign=top;align=left;spacingLeft=12;fontColor=#1A4B8C;fontSize=14;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="devs" value="Desenvolvedores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;" vertex="1" parent="cc">
