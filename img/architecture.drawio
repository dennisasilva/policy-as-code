        <mxCell id="decision" value="Conforme?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FDF3D7;strokeColor=#E8A317;fontColor=#232F3E;" vertex="1" parent="cv">
          <mxGeometry x="210" y="70" width="110" height="80" as="geometry" />
