        </mxCell>
        <mxCell id="repoA" value="App Repo A&#10;(Terraform/CFN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;" vertex="1" parent="cc">
          <mxGeometry x="210" y="45" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="repoB" value="App Repo B&#10;(Terraform/CFN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;" vertex="1" parent="cc">
          <mxGeometry x="210" y="150" width="120" height="70" as="geometry" />
        </mxCell>

        <mxCell id="cr" value="Repositório CENTRAL de regras (policy-as-code)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#3F8DDA;verticalAlign=top;align=left;spacingLeft=12;fontColor=#1A4B8C;fontSize=14;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="pac" value="policy-as-code&#10;(regras por épico)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;" vertex="1" parent="cr">
          <mxGeometry x="20" y="90" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="checkov" value="Checkov&#10;(Terraform)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7FB;strokeColor=#7B42BC;fontColor=#232F3E;" vertex="1" parent="cr">
          <mxGeometry x="205" y="40" width="130" height="70" as="geometry" />
        </mxCell>
        <mxCell id="guard" value="cfn-guard&#10;(CloudFormation)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudformation;" vertex="1" parent="cr">
          <mxGeometry x="245" y="150" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- ================= MIDDLE COLUMN ================= -->
        <mxCell id="cv" value="Validação no Pull Request (GitHub Actions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#3F8DDA;verticalAlign=top;align=left;spacingLeft=12;fontColor=#1A4B8C;fontSize=14;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="295" width="340" height="210" as="geometry" />
        </mxCell>
        <mxCell id="gate" value="Policy Gate&#10;(reusable workflow&#10;on: pull_request)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7FB;strokeColor=#7c3aed;fontColor=#232F3E;" vertex="1" parent="cv">
